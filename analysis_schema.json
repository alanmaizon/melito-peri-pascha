{
  "format": "jsonl",
  "record_keys": {
    "sl": "source line number in greek_raw.txt",
    "src": "source line from greek_raw.txt",
    "ana": "analysis line; only present when it differs from src",
    "emd": "emendation note; omitted when none",
    "tok": "token array; each token = [form, lemma, pos, morph, gloss]",
    "lit": "literal translation",
    "sm": "smooth translation",
    "syn": "syntax object"
  },
  "syntax_keys": {
    "mc": "main clause",
    "sub": "subordinate structures",
    "svo": "subjects, verbs, objects",
    "ptc": "participles",
    "app": "apposition",
    "rhet": "notable rhetorical parallelism"
  },
  "pos_codes": {
    "adjective": "adj",
    "adverb": "adv",
    "article": "art",
    "conjunction": "conj",
    "noun": "noun",
    "pron": "pronoun",
    "participle": "ptcp",
    "particle": "ptcl",
    "preposition": "prep",
    "proper noun": "propn",
    "verb": "verb"
  },
  "morph_style": "compact English abbreviations rather than full prose labels",
  "morph_abbreviations": {
    "nom": "nominative",
    "gen": "genitive",
    "acc": "accusative",
    "dat": "dative",
    "voc": "vocative",
    "1sg": "first person singular",
    "2sg": "second person singular",
    "3sg": "third person singular",
    "1pl": "first person plural",
    "2pl": "second person plural",
    "3pl": "third person plural",
    "sg": "singular",
    "pl": "plural",
    "m": "masculine",
    "f": "feminine",
    "n": "neuter",
    "pred": "predicate",
    "pres": "present",
    "impf": "imperfect",
    "aor": "aorist",
    "pf": "perfect",
    "fut": "future",
    "act": "active",
    "mid": "middle",
    "pass": "passive",
    "mp": "middle/passive",
    "ind": "indicative",
    "imp": "imperative",
    "inf": "infinitive",
    "ptcp": "participle",
    "postpos": "postpositive",
    "coord": "coordinating",
    "subord": "subordinating",
    "advrs": "adversative",
    "dem": "demonstrative",
    "deict": "deictic",
    "expl": "explanatory",
    "interrog": "interrogative",
    "comp": "comparative",
    "temp": "temporal",
    "infer": "inferential",
    "liturg": "liturgical",
    "neg": "negative",
    "indecl": "indeclinable",
    "subst": "substantive use",
    "rel": "relative",
    "+acc": "takes accusative",
    "+dat": "takes dative",
    "+gen": "takes genitive"
  },
  "blank_line_policy": "Blank source lines are omitted from jsonl records and treated only as layout separators."
}
